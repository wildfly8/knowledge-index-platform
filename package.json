{
  "name": "knowledge-index-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Posts vector index sync, archive backfill, and query HTTP API (Spec-Kit)",
  "scripts": {
    "embed:sync": "tsx scripts/embed-posts/sync.ts",
    "embed:backfill": "tsx scripts/embed-posts/backfill.ts",
    "knowledge:worker": "node --max-old-space-size=4096 --import tsx scripts/knowledge-inference-worker.ts",
    "prefetch:xenova": "node scripts/prefetch-xenova-models.mjs",
    "serve": "tsx server/index.ts",
    "postinstall": "node scripts/fix-xenova-sharp.mjs",
    "test": "node --import tsx --test lib/**/*.test.ts",
    "test:iac": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-iac.ps1",
    "test:e2e:cloud": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/e2e/cloud/run.ps1",
    "test:retrieve": "node --import tsx --test lib/knowledge/retrieve*.test.ts lib/knowledge/rerank.test.ts",
    "validate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validate.ps1"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@upstash/vector": "^1.2.3",
    "@xenova/transformers": "^2.17.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "sharp": "$sharp"
  }
}
