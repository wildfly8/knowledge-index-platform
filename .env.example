# Upstash Vector (required for sync / backfill writes)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
# Optional aliases used by some Vercel integrations:
# RAG_UPSTASH_VECTOR_REST_URL=
# RAG_UPSTASH_VECTOR_REST_TOKEN=

# Producer corpus root — separate checkout (e.g. agentic-foundation).
# This repo has NO content/ or data/; paths like content/posts/examined/ are read from CORPUS_ROOT.
CORPUS_ROOT=C:\my_projects\agentic-foundation
# Airflow also accepts:
# AGENTIC_FOUNDATION_REPO=/opt/agentic-foundation

EMBED_PROVIDER=xenova
KNOWLEDGE_INFERENCE_WORKER=0
KNOWLEDGE_WORKER_HEAP_MB=4096

# Feature 002 backfill budget (must be < provider cap)
UPSTASH_DAILY_WRITE_CAP=10000
EMBED_BACKFILL_WRITE_BUDGET=9500
# EMBED_CONVERSATION_ARCHIVES=false
